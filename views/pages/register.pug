extends ../layouts/layout_1.pug
include ../mixins/checkbox_1.pug

block title
  title Đăng ký

block main 
  h1.inner_title Đăng ký
  .inner_desc Tạo một tài khoản để tiếp tục
  form  
    .inner_group
      label.inner_label(for="text") Email
      input.inner_input#text(type="text" placeholder="Ví dụ: Lê Văn A")
    .inner_group
      label.inner_label(for="email") Email
      input.inner_input#email(type="email" placeholder="Ví dụ: levana@gmail.com")
    .inner_group
      label.inner_label(for="pwd") Mật khẩu
      input.inner_input#pwd(type="password")
    .inner_meta 
      +checkbox-1("agree", "Tôi chấp nhận các điều khoản và điều kiện")
    button Đăng Ký
  .inner_more
    span Bạn đã có tài khoản?
    a(href="#") Đăng nhập