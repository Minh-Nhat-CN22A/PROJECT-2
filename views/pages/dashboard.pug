extends ../layouts/layout_2.pug

block title 
  title Tổng quan

block main
  main.main
    .box_title Tổng quan

    //- SECTION 1
    .section_1 
      .inner_item 
        img(src="assets/images/section_1_icon_1.svg", alt="icon")
        .inner_text 
          .inner_title Người dùng
          .inner_number 1.200
      .inner_item 
        img(src="assets/images/section_1_icon_2.svg", alt="icon")
        .inner_text 
          .inner_title Đơn hàng
          .inner_number 3.600
      .inner_item 
        img(src="assets/images/section_1_icon_3.svg", alt="icon")
        .inner_text 
          .inner_title Doanh thu
          .inner_number 300.000.000đ
    //- END SECTION 1

    //- SECTION 2
    .section_2 
      .inner_head 
        .inner_title Biểu đồ doanh thu
        input.inner_input(type="month")
      .inner_chart Vẽ biểu đồ ở đây...
    //- END SECTION 2

    //- SECTION 3
    .section_3 
      .inner_title Đơn hàng mới
      .table_1 
        table 
          thead 
            tr 
              th Mã
              th Thông tin khách
              th Danh sách tour
              th Thanh toán
              th Trạng thái
              th.align_right Ngày đặt
          tbody 
            tr 
              td
                .text_main OD000001
              td 
                div Họ tên: Lê Văn A
                div SĐT: 0123456789
                div Ghi chú: Test...
              td 
                .tour_list 
                  .inner_item 
                    img(src="assets/images/tour_1.png", alt="tour picture")
                    .inner_content 
                      .inner_name Tour Hạ Long
                      .inner_price 
                        div Người lớn: 3 x 1.500.000đ
                        div Trẻ em: 2 x 1.300.000đ
                        div Em bé: 2 x 1.000.000đ
                  .inner_item 
                    img(src="assets/images/tour_1.png", alt="tour picture")
                    .inner_content 
                      .inner_name Tour Hạ Long
                      .inner_price 
                        div Người lớn: 3 x 1.500.000đ
                        div Trẻ em: 2 x 1.300.000đ
                        div Em bé: 2 x 1.000.000đ
              td 
                div Tổng tiền: 10.000.000đ
                div Giảm: 400.000đ
                div Mã giảm: TOURMUAHE2024
                div Thanh toán: 9.600.000đ
                div PTTT: Ví Momo
                div TTTT: Đã thanh toán
              td 
                //- .tag.tag_orange Khởi tạo
                //- .tag.tag_green Đã duyệt
                .tag.tag_red Đã hủy
              td.align_right
                div 16:20
                div 01/01/2024
    //- END SECTION 3