          .inner_title Doanh thu
          .inner_number 300.000.000đ
    //- END SECTION 1

    //- SECTION 2
    .section_2 
      .inner_head 
        .inner_title Biểu đồ doanh thu
        input.inner_input(type="month")
      .inner_chart Vẽ biểu đồ ở đây...
    //- END SECTION 2